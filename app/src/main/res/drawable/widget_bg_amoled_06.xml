<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base: Pure AMOLED black -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF000000" />
        </shape>
    </item>

    <!-- Cyan bloom from bottom-left -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0E00FFCC"
                android:endColor="#00000000"
                android:angle="45" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0E00FFCC"
                android:endColor="#00000000"
                android:angle="45" />
        </shape>
    </item>

    <!-- Magenta bloom from top-right -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0EFF00FF"
                android:endColor="#00000000"
                android:angle="225" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0EFF00FF"
                android:endColor="#00000000"
                android:angle="225" />
        </shape>
    </item>

    <!-- Gold center glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00FFD700"
                android:endColor="#00000000"
                android:angle="135" />
        </shape>
    </item>

    <!-- Blue accent from top-left -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#000066FF"
                android:endColor="#00000000"
                android:angle="315" />
        </shape>
    </item>

    <!-- Purple accent from bottom-right -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#009900FF"
                android:endColor="#00000000"
                android:angle="315" />
        </shape>
    </item>
</layer-list>
